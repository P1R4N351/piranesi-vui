{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/orb/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='PiranesiOrb'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|modulation|audio|intensity|showGlyph|color|offsetX|style|key|ref|className|style|children)$/]",
        "message": "<PiranesiOrb> doesn't accept that prop. Declared props: state, modulation, audio, intensity, showGlyph, color, offsetX, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PiranesiOrb'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:waiting|listening|thinking|talking|working|error)$/]",
        "message": "<PiranesiOrb> state must be one of 'waiting' | 'listening' | 'thinking' | 'talking' | 'working' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PiranesiOrb'] > JSXAttribute[name.name='modulation'] > Literal[value!=/^(?:auto|none|dawn|day|dusk|night|rain|storm|degraded|threat)$/]",
        "message": "<PiranesiOrb> modulation must be one of 'auto' | 'none' | 'dawn' | 'day' | 'dusk' | 'night' | 'rain' | 'storm' | 'degraded' | 'threat'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "PiranesiOrb": {
        "replaces": []
      }
    },
    "tokens": [
